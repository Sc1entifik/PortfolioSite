html
	head
		link(rel="stylesheet", href="/css/styles.css")
		link(rel="stylesheet", href="/css/contact.css")
	body
		div(class="center")
			h2 Contact Request Form
			p Complete the form and I will get back to you as soon as I can. 
			form(id="form", action="/contact" method="post")
				
				div(class="radio-table")
					label(for="radio-table") Reason for contact request:
					table
						tr
							td
								input(id="discord", class="reason", name="reason", type="radio", value="Coffee chat over Discord." checked)
	
							td
								label(for="discord") Coffee chat over Discord.

						tr
							td
								input(id="projects", class="reason", name="reason", type="radio", value="Have a question about one of my projects.")
							td
								label(for="projects") Have a question about one of my projects.
				
						tr
							td
								input(id="employer", class="reason", name="reason", type="radio", value="Potential employer reaching out about an opportunity.")
							td
								label(for="employer") Potential employer reaching out about an opportunity.
				br
					
				label Name: 
					input(class="form-element", type="text", name="name", required)
				br

				label E-mail: 
					input(class="form-element", type="email", name="email", required)
				br

				label(for="message") Message: 
					textarea(class="form-element", id="message", name="message", rows="6", cols="20", required)
				br

				button(class="button", type="submit", value="Submit") Send Message
			
