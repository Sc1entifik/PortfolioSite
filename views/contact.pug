html
	head
		link(rel="stylesheet", href="/css/styles.css")
		link(rel="stylesheet", href="/css/contact.css")
	body
		div(class="center")
			h2 Contact Request Form
			p Complete the form and I will get back to you as soon as I can. 
			form(id="form", action="/contact" method="post")
				
				div(class="radio-flex")
					label(for="radio-flex") Reason for contact request:
					br
					input(id="discord", name="subject", type="radio", value="I would like to schedule a coffee chat over Discord." checked)
					label(for="discord") Coffee chat over Discord.
					br
					input(id="projects", name="subject", type="radio", value="I have a question about one of your projects.")
					label(for="projects") Have a question(s) about one of my projects.
					br
					input(id="employer", name="subject", type="radio", value="I am a potential employer reaching out about an opportunity.")
					label(for="employer") Potential employer reaching out about an opportunity.
					br
					br
					
					label Name:  
						input(class="text-field", type="text", name="name", required)
					br

					label E-mail:  
						input(class="text-field", type="email", name="email", required)
					br

					label(for="message") Message: 
						textarea(class="text-field", id="message", name="message", rows="6", cols="20", required)
					br

					button(type="submit", value="Submit") Send Message
			
